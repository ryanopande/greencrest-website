---

<BaseLayout title="Staff & Administration" description="Meet the dedicated team at Greencrest Advent School">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-green-dark to-green-darker text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Staff & Administration</h1>
      <p class="text-xl text-green-light">Our Dedicated Team</p>
    </div>
  </section>

  <!-- Board & Governance -->
  <section class="section-padding bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-12">Board & Governance</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {boardAndGovernance.map((member) => (
          <div class="card text-center">
            <img
              src={member.photo}
              alt={member.name}
              class="w-48 h-48 rounded-lg object-cover object-top mx-auto mb-4"
              style="object-position: center top;"
              onerror="this.src='https://via.placeholder.com/300x300/a8d5a3/3d6b2f?text=Board+Member'"
            />
            <h3 class="text-xl font-bold text-green-darker mb-2">{member.name}</h3>
            <p class="text-green-dark font-medium mb-3">{member.role}</p>
            <p class="text-gray-600 text-sm">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Leadership Team -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-12">Leadership Team</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {leadershipTeam.map((member) => (
          <div class="card text-center">
            <img
              src={member.photo}
              alt={member.name}
              class="w-48 h-48 rounded-lg object-cover object-top mx-auto mb-4"
              style="object-position: center top;"
              onerror="this.src='https://via.placeholder.com/300x300/a8d5a3/3d6b2f?text=Staff+Photo'"
            />
            <h3 class="text-xl font-bold text-green-darker mb-2">{member.name}</h3>
            <p class="text-green-dark font-medium mb-3">{member.role}</p>
            <p class="text-gray-600 text-sm">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Teaching Staff -->
  <section class="section-padding bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-12">Teaching Staff</h2>
      <p class="text-center text-gray-700 mb-8 max-w-2xl mx-auto">
        Our qualified and experienced teachers are committed to providing quality education and nurturing each student's potential.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {teachingStaff.map((staff) => (
          <div class="card text-center">
            <img
              src={staff.photo}
              alt={staff.name}
              class="w-32 h-32 rounded-lg object-cover object-top mx-auto mb-3"
              style="object-position: center top;"
              onerror="this.src='https://via.placeholder.com/200x200/a8d5a3/3d6b2f?text=Teacher'"
            />
            <h3 class="font-semibold text-green-darker mb-1 text-sm">{staff.name}</h3>
            <p class="text-gray-600 text-xs">{staff.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Support Staff -->
