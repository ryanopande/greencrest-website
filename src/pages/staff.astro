        ))}
      </div>
    </div>
  </section>
  -->

  <!-- Join Our Team -->
  <section class="section-padding bg-green-light/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="heading-primary mb-6">Join Our Team</h2>
      <p class="text-lg text-gray-700 mb-8">
        We are always looking for dedicated, qualified educators and staff who share our commitment to excellence in Christian education.
      </p>
      <a href="/contact" class="btn-primary inline-block">
        Contact Us About Opportunities
      </a>
    </div>
  </section>
</BaseLayout>
