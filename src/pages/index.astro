---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Greencrest Advent School - Excellence in Faith & Learning from ECD to Grade 9">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-green-dark to-green-darker text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/staff/school-building.jpg"
        alt=""
        class="w-full h-full object-cover"
        onerror="this.style.display='none'"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-green-dark/40 to-green-darker/50"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 md:py-48 lg:py-64 min-h-[70vh] flex items-center">
      <div class="text-center fade-in-up">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          Welcome to Greencrest Advent School
        </h1>
        <p class="text-xl md:text-2xl mb-4 text-green-light">
          Karibu - Excellence in Faith, Academics & Character
        </p>
        <p class="text-lg md:text-xl mb-8 max-w-3xl mx-auto">
          Nurturing young minds from ECD to Grade 9 with a foundation built on faith, academic excellence, and holistic development.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/admissions" class="btn-primary inline-block text-center">
            Apply Now
          </a>
          <a href="/about" class="btn-secondary inline-block text-center bg-white/10 border-white text-white hover:bg-white hover:text-green-dark">
            Learn More
          </a>
        </div>
      </div>
    </div>
    <!-- Decorative element -->
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-cream"></div>
  </section>

  <!-- School Introduction -->
  <section class="section-padding bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="heading-primary">Our Mission</h2>
          <p class="text-lg mb-4 text-gray-700">
            At Greencrest Advent School, we are committed to providing a Christ-centered education that develops the whole child—spiritually, academically, physically, and socially. Our mission is to nurture students who are not only academically excellent but also morally upright and service-oriented.
          </p>
          <p class="text-lg mb-4 text-gray-700">
            We believe in creating a supportive environment where every child can discover their God-given potential and grow into responsible citizens who make a positive difference in their communities.
          </p>
          <p class="text-lg mb-6 text-gray-700 font-semibold text-green-dark">
            No Child Left Behind
          </p>
          <a href="/about" class="btn-primary inline-block">
            Read Our Story
          </a>
        </div>
        <div class="relative">
          <img
            src="/images/staff/building.jpg"
            alt="Greencrest Advent School"
            class="w-full h-64 object-cover rounded-lg shadow-lg"
            onerror="this.src='https://via.placeholder.com/800x600/a8d5a3/3d6b2f?text=Greencrest+Advent+School'"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Key Pillars -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="heading-primary">Our Foundation</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Four pillars that guide everything we do at Greencrest Advent School
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Faith -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-green-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="heading-tertiary">Faith</h3>
          <p class="text-gray-600">
            A Christ-centered education that integrates faith with learning, helping students develop a personal relationship with God.
          </p>
        </div>

        <!-- Academics -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-green-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="heading-tertiary">Academics</h3>
          <p class="text-gray-600">
            Rigorous academic programs that challenge students to achieve their highest potential while fostering critical thinking and creativity.
          </p>
        </div>

        <!-- Character -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-green-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="heading-tertiary">Character</h3>
          <p class="text-gray-600">
            Building integrity, respect, responsibility, and compassion through daily practice and positive role modeling.
          </p>
        </div>

        <!-- Holistic Development -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-green-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="heading-tertiary">Holistic Development</h3>
          <p class="text-gray-600">
            Nurturing the whole child through sports, arts, music, and service opportunities that develop well-rounded individuals.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Student Life Preview -->
  <section class="section-padding bg-green-light/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="heading-primary">Student Life</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          A vibrant community where students learn, grow, and thrive together
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card overflow-hidden">
          <img
            src="/images/staff/boarding-life.jpg"
            alt="Boarding Life"
            class="w-full h-48 object-cover"
            onerror="this.src='https://via.placeholder.com/600x400/a8d5a3/3d6b2f?text=Boarding+Life'"
          />
          <div class="p-6">
            <h3 class="heading-tertiary">Boarding Life</h3>
            <p class="text-gray-600 mb-4">
              A home away from home with caring staff, structured routines, and opportunities for growth.
            </p>
            <a href="/student-life#boarding" class="text-green-dark hover:text-green-darker font-medium">
              Learn more →
            </a>
          </div>
        </div>
        <div class="card overflow-hidden">
          <img
            src="/images/staff/clubs-sports.jpg"
            alt="Clubs and Sports"
            class="w-full h-48 object-cover"
            onerror="this.src='https://via.placeholder.com/600x400/a8d5a3/3d6b2f?text=Clubs+and+Sports'"
          />
          <div class="p-6">
            <h3 class="heading-tertiary">Clubs & Sports</h3>
            <p class="text-gray-600 mb-4">
              From debate to football, music to science club—something for every interest.
            </p>
            <a href="/student-life#clubs" class="text-green-dark hover:text-green-darker font-medium">
              Learn more →
            </a>
          </div>
        </div>
        <div class="card overflow-hidden">
          <img
            src="/images/staff/meals-welfare.jpg"
            alt="Meals and Welfare"
            class="w-full h-48 object-cover"
            onerror="this.src='https://via.placeholder.com/600x400/a8d5a3/3d6b2f?text=Meals+and+Welfare'"
          />
          <div class="p-6">
            <h3 class="heading-tertiary">Meals & Welfare</h3>
            <p class="text-gray-600 mb-4">
              Nutritious meals and comprehensive student welfare support for every child.
            </p>
            <a href="/student-life#welfare" class="text-green-dark hover:text-green-darker font-medium">
              Learn more →
            </a>
          </div>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="/student-life" class="btn-primary inline-block">
          Explore Student Life
        </a>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="section-padding bg-green-dark text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Join Our Community?</h2>
      <p class="text-xl mb-8 text-green-light">
        Discover how Greencrest Advent School can help your child thrive. Tuko pamoja—we are together in this journey.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/admissions" class="btn-primary bg-white text-green-dark hover:bg-green-light inline-block">
          Start Your Application
        </a>
        <a href="/contact" class="btn-secondary border-white text-white hover:bg-white hover:text-green-dark inline-block">
          Book a Visit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Simple scroll-based fade-in animation
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('fade-in-up');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Observe all cards and sections
  document.querySelectorAll('.card, section > div').forEach(el => {
    observer.observe(el);
  });
</script>
