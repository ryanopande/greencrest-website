---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Student Life" description="Explore boarding life, clubs, sports, meals, and student welfare at Greencrest Advent School">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-green-dark to-green-darker text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Student Life</h1>
      <p class="text-xl text-green-light">A Vibrant Community Where Students Thrive</p>
    </div>
  </section>

  <!-- Boarding Life -->
  <section class="section-padding bg-white" id="boarding">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="heading-primary">Boarding Life</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          A home away from home where students learn independence, responsibility, and community living
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <img
            src="/images/staff/boarding-dormitory.jpg"
            alt="Boarding Dormitory"
            class="w-full rounded-lg shadow-xl"
            onerror="this.src='https://via.placeholder.com/800x600/a8d5a3/3d6b2f?text=Boarding+Dormitory'"
          />
        </div>
        <div>
          <h3 class="heading-secondary mb-4">A Supportive Environment</h3>
          <p class="text-gray-700 mb-4">
            Our boarding program provides a safe, structured, and nurturing environment where students can focus on their studies while developing life skills and lasting friendships.
          </p>
          <ul class="space-y-3 text-gray-700 mb-6">
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Comfortable, well-maintained dormitories with appropriate supervision</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Structured daily routines that balance study, rest, and recreation</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Dedicated boarding staff who care for students' physical and emotional well-being</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Evening study sessions with academic support</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Weekend activities and outings</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Regular communication with parents and guardians</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Clubs and Sports -->
  <section class="section-padding bg-cream" id="clubs">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="heading-primary">Clubs & Sports</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Opportunities for every student to explore interests, develop talents, and build friendships
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Academic Clubs -->
        <div class="card">
          <h3 class="heading-tertiary mb-3">Academic Clubs</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Science Club</li>
            <li>• Mathematics Club</li>
            <li>• Debate Club</li>
            <li>• Reading Club</li>
            <li>• Chess Club</li>
          </ul>
        </div>
        <!-- Creative Arts -->
        <div class="card">
          <h3 class="heading-tertiary mb-3">Creative Arts</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Music Club</li>
            <li>• Art & Craft</li>
            <li>• Drama Club</li>
            <li>• Choir</li>
            <li>• Poetry Club</li>
          </ul>
        </div>
        <!-- Sports -->
        <div class="card">
          <h3 class="heading-tertiary mb-3">Sports</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Football</li>
            <li>• Swimming</li>
            <li>• Athletics</li>
            <li>• Volleyball</li>
            <li>• Netball</li>
          </ul>
        </div>
        <!-- Service & Leadership -->
        <div class="card">
          <h3 class="heading-tertiary mb-3">Service & Leadership</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Student Council</li>
            <li>• Community Service</li>
            <li>• Environmental Club</li>
            <li>• Pathfinders/Scouts</li>
          </ul>
        </div>
        <!-- Cultural -->
        <div class="card">
          <h3 class="heading-tertiary mb-3">Cultural</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Swahili Club</li>
            <li>• Cultural Dance</li>
            <li>• Heritage Club</li>
          </ul>
        </div>
        <!-- Science & Technology -->
        <div class="card">
          <h3 class="heading-tertiary mb-3">Science & Technology</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Computer Club</li>
            <li>• Young Farmers Club</li>
          </ul>
        </div>
      </div>
      <div class="mt-8 text-center">
        <p class="text-gray-700">
          Clubs meet regularly and participate in competitions, performances, and community events. All students are encouraged to join at least one club that interests them.
        </p>
      </div>
    </div>
  </section>

  <!-- Meals and Student Welfare -->
  <section class="section-padding bg-white" id="welfare">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="heading-primary">Meals & Student Welfare</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Nourishing bodies and caring for the whole child
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Meals -->
        <div class="card">
          <h3 class="heading-secondary mb-4">Nutritious Meals</h3>
          <p class="text-gray-700 mb-4">
            We believe that healthy, balanced meals are essential for student well-being and academic performance. Our kitchen staff prepares fresh, nutritious meals daily.
          </p>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Three balanced meals per day for boarding students</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Mid-morning snack and afternoon tea</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Lunch available for day students</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Special dietary needs accommodated</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Clean, hygienic dining facilities</span>
            </li>
          </ul>
        </div>
        <!-- Student Welfare -->
        <div class="card">
          <h3 class="heading-secondary mb-4">Student Welfare</h3>
          <p class="text-gray-700 mb-4">
            The well-being of every student is our priority. We provide comprehensive support to ensure students feel safe, valued, and cared for.
          </p>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>School counselor available for emotional and social support</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Health services and first aid on campus</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Regular health check-ups and wellness programs</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Anti-bullying policies and programs</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Open communication channels between school, students, and parents</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">✓</span>
              <span>Safe and secure campus environment</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="mt-12">
        <img
          src="/images/student-welfare.jpg"
          alt="Student Welfare"
          class="w-full rounded-lg shadow-xl"
          onerror="this.src='https://via.placeholder.com/1200x600/a8d5a3/3d6b2f?text=Student+Welfare'"
        />
      </div>
    </div>
  </section>

  <!-- Daily Schedule -->
  <section class="section-padding bg-green-light/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-8">A Day in the Life</h2>
      <div class="card">
        <div class="space-y-4">
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">6:00 AM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Wake Up & Morning Devotion</h4>
              <p class="text-gray-600 text-sm">Boarding students start the day with prayer and preparation</p>
            </div>
          </div>
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">7:00 AM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Breakfast</h4>
              <p class="text-gray-600 text-sm">Nutritious meal to fuel the day</p>
            </div>
          </div>
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">8:00 AM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Classes Begin</h4>
              <p class="text-gray-600 text-sm">Academic instruction and learning activities</p>
            </div>
          </div>
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">10:30 AM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Break Time</h4>
              <p class="text-gray-600 text-sm">Snack and recreation</p>
            </div>
          </div>
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">1:00 PM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Lunch</h4>
              <p class="text-gray-600 text-sm">Midday meal and rest</p>
            </div>
          </div>
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">2:00 PM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Afternoon Classes</h4>
              <p class="text-gray-600 text-sm">Continued learning and activities</p>
            </div>
          </div>
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">4:00 PM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Clubs & Sports</h4>
              <p class="text-gray-600 text-sm">Extracurricular activities and recreation</p>
            </div>
          </div>
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">6:00 PM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Dinner</h4>
              <p class="text-gray-600 text-sm">Evening meal (boarding students)</p>
            </div>
          </div>
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">7:00 PM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Study Time</h4>
              <p class="text-gray-600 text-sm">Supervised homework and study sessions</p>
            </div>
          </div>
          <div class="flex items-start border-l-4 border-green-dark pl-4">
            <div class="flex-shrink-0 w-20 text-green-dark font-semibold">9:00 PM</div>
            <div class="flex-1">
              <h4 class="font-semibold text-gray-800">Evening Devotion & Rest</h4>
              <p class="text-gray-600 text-sm">Reflection, prayer, and preparation for rest</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
