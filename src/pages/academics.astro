---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Academics" description="Explore our academic programs from ECD to Grade 9">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-green-dark to-green-darker text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Academics</h1>
      <p class="text-xl text-green-light">Excellence in Learning from ECD to Grade 9</p>
    </div>
  </section>

  <!-- Overview -->
  <section class="section-padding bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg text-gray-700 mb-8">
        At Greencrest Advent School, we offer a comprehensive academic program that challenges students to achieve their highest potential while integrating faith with learning. Our curriculum follows the Kenyan national curriculum, enhanced with Adventist education principles.
      </p>
    </div>
  </section>

  <!-- ECD -->
  <section class="section-padding bg-cream" id="ecd">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="heading-primary">Early Childhood Development (ECD)</h2>
          <p class="text-lg text-gray-700 mb-4">
            Our ECD program provides a nurturing foundation for young learners, focusing on holistic development through play-based learning, structured activities, and age-appropriate academic preparation.
          </p>
          <ul class="space-y-2 text-gray-700 mb-6">
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Age-appropriate curriculum focusing on literacy, numeracy, and life skills</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Play-based learning that encourages creativity and exploration</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Character development through stories, songs, and daily routines</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Safe, caring environment with experienced early childhood educators</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Preparation for smooth transition to primary school</span>
            </li>
          </ul>
        </div>
        <div>
          <img
            src="/images/staff/academics-ecd.jpg"
            alt="ECD Students"
            class="w-full rounded-lg shadow-xl"
            onerror="this.src='https://via.placeholder.com/800x600/a8d5a3/3d6b2f?text=ECD+Program'"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Lower Primary -->
  <section class="section-padding bg-white" id="lower-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <img
            src="/images/staff/academics-lower-primary.jpg"
            alt="Lower Primary Students"
            class="w-full rounded-lg shadow-xl"
            onerror="this.src='https://via.placeholder.com/800x600/a8d5a3/3d6b2f?text=Lower+Primary'"
          />
        </div>
        <div class="order-1 lg:order-2">
          <h2 class="heading-primary">Lower Primary (Grades 1-3)</h2>
          <p class="text-lg text-gray-700 mb-4">
            Lower Primary builds on the foundation laid in ECD, developing essential literacy and numeracy skills while fostering curiosity and a love for learning.
          </p>
          <ul class="space-y-2 text-gray-700 mb-6">
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Core subjects: English, Kiswahili, Mathematics, Science, Social Studies, Religious Education</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Emphasis on reading fluency, writing skills, and mathematical thinking</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Creative arts, music, and physical education integrated into the curriculum</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Character education woven into daily lessons and activities</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Individual attention to ensure every child progresses at their pace</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Upper Primary -->
  <section class="section-padding bg-cream" id="upper-primary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="heading-primary">Upper Primary (Grades 4-6)</h2>
          <p class="text-lg text-gray-700 mb-4">
            Upper Primary deepens academic knowledge and skills while preparing students for the transition to junior school. Students develop greater independence and critical thinking abilities.
          </p>
          <ul class="space-y-2 text-gray-700 mb-6">
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Expanded curriculum with more specialized subject areas</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Project-based learning that encourages research and presentation skills</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Preparation for KPSEA with comprehensive revision and exam techniques</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Leadership opportunities through class responsibilities and student council</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Enhanced focus on problem-solving and analytical thinking</span>
            </li>
          </ul>
        </div>
        <div>
          <img
            src="/images/staff/academics-upper-primary.jpg"
            alt="Upper Primary Students"
            class="w-full rounded-lg shadow-xl"
            onerror="this.src='https://via.placeholder.com/800x600/a8d5a3/3d6b2f?text=Upper+Primary'"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Junior School -->
  <section class="section-padding bg-white" id="junior-school">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <img
            src="/images/staff/academics-junior-school.jpg"
            alt="Junior School Students"
            class="w-full rounded-lg shadow-xl"
            onerror="this.src='https://via.placeholder.com/800x600/a8d5a3/3d6b2f?text=Junior+School'"
          />
        </div>
        <div class="order-1 lg:order-2">
          <h2 class="heading-primary">Junior School (Grades 7-9)</h2>
          <p class="text-lg text-gray-700 mb-4">
            Junior School provides a rigorous academic program that prepares students for secondary education while continuing to develop character, leadership, and service-oriented mindsets.
          </p>
          <ul class="space-y-2 text-gray-700 mb-6">
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Comprehensive curriculum aligned with national standards</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Subject specialization with qualified teachers in each discipline</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Preparation for KPSEA and transition to secondary school</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Enhanced critical thinking, research, and independent study skills</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Leadership development and mentorship programs</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-dark mr-2">•</span>
              <span>Career guidance and academic counseling</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Academic Excellence -->
  <section class="section-padding bg-green-light/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="heading-primary mb-6">Academic Excellence</h2>
      <p class="text-lg text-gray-700 mb-4">
        Our commitment to academic excellence is reflected in our qualified teaching staff, well-equipped classrooms, and supportive learning environment. We believe every child can achieve their potential with the right support and encouragement.
      </p>
      <p class="text-lg text-gray-700 mb-8 font-semibold text-green-dark">
        No Child Left Behind
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card text-center">
          <h3 class="heading-tertiary mb-3">Qualified Teachers</h3>
          <p class="text-gray-700">Experienced, dedicated educators committed to student success</p>
        </div>
        <div class="card text-center">
          <h3 class="heading-tertiary mb-3">Modern Facilities</h3>
          <p class="text-gray-700">Well-equipped classrooms and learning resources</p>
        </div>
        <div class="card text-center">
          <h3 class="heading-tertiary mb-3">Individual Support</h3>
          <p class="text-gray-700">Personalized attention to help each student thrive</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
