---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Admissions" description="Learn how to apply to Greencrest Advent School - Requirements, fees, and application process">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-green-dark to-green-darker text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Admissions</h1>
      <p class="text-xl text-green-light">Join the Greencrest Advent School Community</p>
    </div>
  </section>

  <!-- How to Apply -->
  <section class="section-padding bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-8">How to Apply</h2>
      <div class="space-y-6">
        <div class="card">
          <div class="flex items-start">
            <div class="flex-shrink-0 w-10 h-10 bg-green-dark text-white rounded-full flex items-center justify-center font-bold mr-4">
              1
            </div>
            <div>
              <h3 class="heading-tertiary mb-2">Inquiry & Visit</h3>
              <p class="text-gray-700">
                Contact our admissions office to learn more about the school and schedule a visit. We encourage families to tour our facilities and meet with our staff to see if Greencrest Advent School is the right fit for your child.
              </p>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="flex items-start">
            <div class="flex-shrink-0 w-10 h-10 bg-green-dark text-white rounded-full flex items-center justify-center font-bold mr-4">
              2
            </div>
            <div>
              <h3 class="heading-tertiary mb-2">Application Form</h3>
              <p class="text-gray-700">
                Complete the application form, which can be obtained from our admissions office or downloaded from our website. Submit the completed form along with required documents (see Requirements section below).
              </p>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="flex items-start">
            <div class="flex-shrink-0 w-10 h-10 bg-green-dark text-white rounded-full flex items-center justify-center font-bold mr-4">
              3
            </div>
            <div>
              <h3 class="heading-tertiary mb-2">Assessment & Interview</h3>
              <p class="text-gray-700">
                Students may be required to take an assessment test appropriate to their grade level. An interview with the student and parents may also be conducted to ensure a good fit between the family and the school's values and expectations.
              </p>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="flex items-start">
            <div class="flex-shrink-0 w-10 h-10 bg-green-dark text-white rounded-full flex items-center justify-center font-bold mr-4">
              4
            </div>
            <div>
              <h3 class="heading-tertiary mb-2">Acceptance & Enrollment</h3>
              <p class="text-gray-700">
                Upon acceptance, you will receive an offer letter. Complete the enrollment process by submitting required fees and documentation. Our admissions team will guide you through each step.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Requirements -->
  <section class="section-padding bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-8">Admission Requirements</h2>
      <div class="card">
        <h3 class="heading-tertiary mb-4">Required Documents</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex items-start">
            <span class="text-green-dark mr-2">✓</span>
            <span>Completed application form</span>
          </li>
          <li class="flex items-start">
            <span class="text-green-dark mr-2">✓</span>
            <span>Birth certificate (original and copy)</span>
          </li>
          <li class="flex items-start">
            <span class="text-green-dark mr-2">✓</span>
            <span>Previous school reports (for transfers)</span>
          </li>
          <li class="flex items-start">
            <span class="text-green-dark mr-2">✓</span>
            <span>Medical records and immunization card</span>
          </li>
          <li class="flex items-start">
            <span class="text-green-dark mr-2">✓</span>
            <span>Two recent passport-size photographs</span>
          </li>
          <li class="flex items-start">
            <span class="text-green-dark mr-2">✓</span>
            <span>Parent/guardian identification documents</span>
          </li>
          <li class="flex items-start">
            <span class="text-green-dark mr-2">✓</span>
            <span>Transfer letter (if applicable)</span>
          </li>
        </ul>
      </div>
      <div class="card mt-6">
        <h3 class="heading-tertiary mb-4">Age Requirements</h3>
        <ul class="space-y-2 text-gray-700">
          <li><strong>ECD:</strong> 3-5 years old</li>
          <li><strong>Grade 1:</strong> 6 years old by January 1st</li>
          <li><strong>Grade 2-9:</strong> Age-appropriate for grade level</li>
        </ul>
        <p class="text-gray-600 mt-4 italic">
          Note: Age requirements may vary slightly. Please contact our admissions office for specific guidance.
        </p>
      </div>
    </div>
  </section>

  <!-- Fees Overview -->
  <section class="section-padding bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-8">Fees Overview</h2>
      <div class="card">
        <p class="text-gray-700 mb-6">
          At Greencrest Advent School, we are committed to providing quality education at reasonable fees. Our fee structure includes tuition, boarding (for boarding students), meals, and other essential services.
        </p>
        <div class="bg-green-light/20 p-6 rounded-lg mb-6">
          <h3 class="heading-tertiary mb-4">Fee Structure (2024 Academic Year)</h3>
          <div class="space-y-4">
            <div class="flex justify-between items-center border-b border-green-dark/20 pb-2">
              <span class="text-gray-700">Tuition (Day Students)</span>
              <span class="font-semibold text-green-dark">Contact for details</span>
            </div>
            <div class="flex justify-between items-center border-b border-green-dark/20 pb-2">
              <span class="text-gray-700">Tuition + Boarding</span>
              <span class="font-semibold text-green-dark">Contact for details</span>
            </div>
            <div class="flex justify-between items-center border-b border-green-dark/20 pb-2">
              <span class="text-gray-700">Application Fee (One-time)</span>
              <span class="font-semibold text-green-dark">KES 2,000</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-700">Development Fee (Annual)</span>
              <span class="font-semibold text-green-dark">Contact for details</span>
            </div>
          </div>
        </div>
        <p class="text-gray-600 text-sm">
          <strong>Note:</strong> Fees are subject to change. Please contact our admissions office for the most current fee structure and payment plans. We offer flexible payment options and scholarships for qualifying students.
        </p>
      </div>
    </div>
  </section>

  <!-- Book a Visit Form -->
  <section class="section-padding bg-cream">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-8">Book a Visit</h2>
      <div class="card">
        <p class="text-gray-700 mb-6">
          We'd love to show you around! Schedule a visit to tour our facilities, meet our staff, and learn more about what makes Greencrest Advent School special.
        </p>
        <form class="space-y-6" id="visit-form" action="https://formspree.io/f/xeerzpae" method="POST">
          <div>
            <label for="parent-name" class="block text-sm font-medium text-gray-700 mb-2">
              Parent/Guardian Name *
            </label>
            <input
              type="text"
              id="parent-name"
              name="parent-name"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              Email Address *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
              Phone Number *
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            />
          </div>
          <div>
            <label for="student-name" class="block text-sm font-medium text-gray-700 mb-2">
              Student Name
            </label>
            <input
              type="text"
              id="student-name"
              name="student-name"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            />
          </div>
          <div>
            <label for="grade" class="block text-sm font-medium text-gray-700 mb-2">
              Grade of Interest
            </label>
            <select
              id="grade"
              name="grade"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            >
              <option value="">Select grade</option>
              <option value="ecd">ECD</option>
              <option value="grade-1">Grade 1</option>
              <option value="grade-2">Grade 2</option>
              <option value="grade-3">Grade 3</option>
              <option value="grade-4">Grade 4</option>
              <option value="grade-5">Grade 5</option>
              <option value="grade-6">Grade 6</option>
              <option value="grade-7">Grade 7</option>
              <option value="grade-8">Grade 8</option>
              <option value="grade-9">Grade 9</option>
            </select>
          </div>
          <div>
            <label for="preferred-date" class="block text-sm font-medium text-gray-700 mb-2">
              Preferred Visit Date
            </label>
            <input
              type="date"
              id="preferred-date"
              name="preferred-date"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
              Additional Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            ></textarea>
          </div>
          <button type="submit" class="btn-primary w-full">
            Submit Visit Request
          </button>
        </form>
        
        <div id="visit-success-message" class="hidden mt-4 p-3 text-center text-gray-700">
          ✓ Visit request received. We'll contact you soon to confirm.
        </div>
        <div id="visit-error-message" class="hidden mt-4 p-3 text-center text-gray-700">
          Something went wrong. Please try again.
        </div>
        
        <p class="text-sm text-gray-600 mt-4 text-center">
          We'll contact you within 24-48 hours to confirm your visit. Karibu!
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Admissions -->
  <section class="section-padding bg-green-dark text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Questions About Admissions?</h2>
      <p class="text-xl mb-8 text-green-light">
        Our admissions team is here to help. Contact us for more information or to schedule a visit.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary bg-white text-green-dark hover:bg-green-light inline-block">
          Contact Us
        </a>
        <a
          href="https://wa.me/254727568790"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary border-white text-white hover:bg-white hover:text-green-dark inline-block"
        >
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('visit-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const form = e.target;
    const submitButton = form.querySelector('button[type="submit"]');
    const originalText = submitButton.textContent;
    
    submitButton.textContent = 'Sending...';
    submitButton.disabled = true;
    
    const formData = new FormData(form);
    
    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });
      
      if (response.ok) {
        document.getElementById('visit-success-message').classList.remove('hidden');
        form.reset();
        setTimeout(() => {
          document.getElementById('visit-success-message').classList.add('hidden');
        }, 5000);
      } else {
        document.getElementById('visit-error-message').classList.remove('hidden');
      }
    } catch (error) {
      document.getElementById('visit-error-message').classList.remove('hidden');
    } finally {
      submitButton.textContent = originalText;
      submitButton.disabled = false;
    }
  });
</script>
