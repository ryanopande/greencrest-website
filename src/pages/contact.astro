---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Get in touch with Greencrest Advent School - Phone, email, WhatsApp, and visiting hours">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-green-dark to-green-darker text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
      <p class="text-xl text-green-light">We'd Love to Hear from You - Karibu!</p>
    </div>
  </section>

  <!-- Contact Information -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Phone -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-green-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="heading-tertiary mb-3">Phone</h3>
          <p class="text-gray-700 mb-2">
            <a href="tel:+254727568790" class="text-green-dark hover:text-green-darker">
              +254 727 568 790
            </a>
          </p>
          <p class="text-gray-600 text-sm">Monday - Friday: 8:00 AM - 5:00 PM</p>
        </div>

        <!-- Email -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-green-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="heading-tertiary mb-3">Email</h3>
          <p class="text-gray-700 mb-2">
            <a href="mailto:info@greencrestadvent.com" class="text-green-dark hover:text-green-darker">
              info@greencrestadvent.com
            </a>
          </p>
          <p class="text-gray-600 text-sm">We respond within 24-48 hours</p>
        </div>

        <!-- WhatsApp -->
        <div class="card text-center">
          <div class="w-16 h-16 bg-green-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-dark" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </div>
          <h3 class="heading-tertiary mb-3">WhatsApp</h3>
          <a
            href="https://wa.me/254727568790"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary inline-block"
          >
            Chat with Us
          </a>
          <p class="text-gray-600 text-sm mt-2">Quick responses via WhatsApp</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visiting Hours -->
  <section class="section-padding bg-cream">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-8">Visiting Hours</h2>
      <div class="card">
        <div class="space-y-4">
          <div>
            <h3 class="heading-tertiary mb-2">School Office</h3>
            <p class="text-gray-700">
              <strong>Monday - Friday:</strong> 8:00 AM - 5:00 PM<br>
              <strong>Saturday:</strong> 9:00 AM - 1:00 PM<br>
              <strong>Sunday:</strong> Closed
            </p>
          </div>
          <div class="border-t border-gray-200 pt-4">
            <h3 class="heading-tertiary mb-2">School Tours</h3>
            <p class="text-gray-700 mb-4">
              We welcome prospective families to visit our school. Please schedule your visit in advance to ensure we can provide you with the best experience.
            </p>
            <a href="/admissions#visit" class="btn-primary inline-block">
              Schedule a Visit
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section-padding bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="heading-primary text-center mb-8">Send Us a Message</h2>
      <div class="card">
        <form class="space-y-6" id="contact-form" action="https://formspree.io/f/mnjgzoqy" method="POST">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
              Your Name *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              Email Address *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
              Phone Number
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">
              Subject *
            </label>
            <select
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            >
              <option value="">Select a subject</option>
              <option value="admissions">Admissions Inquiry</option>
              <option value="general">General Inquiry</option>
              <option value="academics">Academic Questions</option>
              <option value="boarding">Boarding Information</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
              Message *
            </label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-dark focus:border-green-dark"
            ></textarea>
          </div>
          <button type="submit" class="btn-primary w-full">
            Send Message
          </button>
        </form>
        
        <div id="success-message" class="hidden mt-4 p-3 text-center text-gray-700">
          ✓ Got your message. We'll be in touch soon.
        </div>
        <div id="error-message" class="hidden mt-4 p-3 text-center text-gray-700">
          Something went wrong. Please try again.
        </div>
        
        <p class="text-sm text-gray-600 mt-4 text-center">
          We'll respond to your message as soon as possible. Asante sana!
        </p>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="section-padding bg-green-light/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="heading-primary mb-6">Find Us</h2>
      <p class="text-lg text-gray-700 mb-4">
        Greencrest Advent School<br>
        903 Moi's Bridge<br>
        Trans-Nzoia, Kenya
      </p>
      <p class="text-gray-600">
        For detailed directions, please contact our office or use the WhatsApp button above.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const form = e.target;
    const submitButton = form.querySelector('button[type="submit"]');
    const originalText = submitButton.textContent;
    
    submitButton.textContent = 'Sending...';
    submitButton.disabled = true;
    
    const formData = new FormData(form);
    
    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });
      
      if (response.ok) {
        document.getElementById('success-message').classList.remove('hidden');
        form.reset();
        // Hide success message after 5 seconds
        setTimeout(() => {
          document.getElementById('success-message').classList.add('hidden');
        }, 5000);
      } else {
        document.getElementById('error-message').classList.remove('hidden');
      }
    } catch (error) {
      document.getElementById('error-message').classList.remove('hidden');
    } finally {
      submitButton.textContent = originalText;
      submitButton.disabled = false;
    }
  });
</script>
