---
const currentYear = new Date().getFullYear();
---

<footer class="bg-green-darker text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- School Info -->
      <div>
        <h3 class="text-xl font-bold mb-4">Greencrest Advent School</h3>
        <p class="text-green-light mb-4">
          A Tradition of Excellence
        </p>
        <p class="text-sm text-green-light italic mb-2"> No Child Left Behind</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-xl font-bold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-green-light hover:text-white transition-colors">About Us</a></li>
          <li><a href="/admissions" class="text-green-light hover:text-white transition-colors">Admissions</a></li>
          <li><a href="/calendar" class="text-green-light hover:text-white transition-colors">School Calendar</a></li>
          <li><a href="/contact" class="text-green-light hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-xl font-bold mb-4">Contact</h3>
        <ul class="space-y-2 text-green-light">
          <li>Email: info@greencrestadvent.com</li>
          <li>Phone: +254 727 568 790</li>
          <li>WhatsApp: +254 727 568 790</li>
        </ul>
        <a
          href="https://wa.me/254727568790"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center space-x-2 bg-green-medium hover:bg-green-dark px-4 py-2 rounded-lg transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          <span>Chat on WhatsApp</span>
        </a>
      </div>
    </div>

    <div class="border-t border-green-dark mt-8 pt-8 text-center text-sm text-green-light">
      <p>&copy; {currentYear} Greencrest Advent School. All rights reserved.</p>
      <p class="mt-2">
        <a href="/safeguarding" class="hover:text-white transition-colors">Safeguarding & Privacy</a>
      </p>
    </div>
  </div>
</footer>
